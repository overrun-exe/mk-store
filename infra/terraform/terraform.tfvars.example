yc_token           = "replace-with-oauth-token"
cloud_id           = "replace-with-cloud-id"
folder_id          = "replace-with-folder-id"
zone               = "ru-central1-a"
network_cidr       = "10.10.0.0/24"
cluster_name       = "mk-store"
kubernetes_version = "1.30"
node_count         = 2
node_cores         = 2
node_memory        = 4
node_disk_size     = 30
node_disk_type     = "network-hdd"
node_preemptible   = true
ssh_public_key     = "ssh-ed25519 AAAA..."
tfstate_bucket_name = "mk-store-tfstate"
assets_bucket_name  = "mk-store-assets"
storage_access_key  = "replace-with-access-key"
storage_secret_key  = "replace-with-secret-key"
